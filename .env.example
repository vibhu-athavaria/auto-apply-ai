# Database Configuration
DATABASE_URL=postgresql+asyncpg://linkedin_user:linkedin_password@localhost:5432/linkedin_autopilot
POSTGRES_USER=linkedin_user
POSTGRES_PASSWORD=linkedin_password
POSTGRES_DB=linkedin_autopilot

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.doc,.docx

# Logging Configuration
LOG_LEVEL=INFO

# LinkedIn Automation Configuration (Worker Service)
# Get li_at cookie from LinkedIn after logging in
LINKEDIN_SESSION_COOKIE=
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30000

# Rate Limiting
DAILY_SEARCH_LIMIT=50
DAILY_APPLICATION_LIMIT=20

# Delay Settings (seconds) - for human-like behavior
MIN_ACTION_DELAY=1.0
MAX_ACTION_DELAY=3.0
MIN_NAVIGATION_DELAY=2.0
MAX_NAVIGATION_DELAY=5.0
MIN_SEARCH_DELAY=3.0
MAX_SEARCH_DELAY=8.0

# Retry Settings
MAX_RETRIES=3
BASE_BACKOFF_DELAY=1.0
